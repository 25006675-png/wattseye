# Meta WhatsApp Cloud API credentials
# From developers.facebook.com → your app → WhatsApp → API Setup
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=000000000000000
META_RECIPIENT=60xxxxxxxxx

# Webhook verification token — any string you choose; paste the SAME value into
# the Meta App dashboard webhook config so the GET handshake matches.
META_VERIFY_TOKEN=choose-any-string

# Gemini API for LLM rephrase of WhatsApp messages (free tier OK)
# Get one from https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIzaSy...

# Language for WhatsApp messages — one of: en | malay | mix
# en    = pure English
# malay = pure Bahasa Malaysia
# mix   = English with light Manglish / Malaysian slang (default)
# WATTSEYE_LANG=mix
